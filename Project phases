def analyze_incident(alert):

    cpu = int(alert["cpu"])

    service = alert["service"]

    if cpu > 90:

        cause = "Traffic Spike"

        recommendation = "Scale Pods"

    elif cpu > 80:

        cause = "High Load"

        recommendation = "Monitor Closely"

    else:

        cause = "Unknown"

        recommendation = "Manual Investigation"

    report = {

        "service": service,

        "cause": cause,

        "recommendation": recommendation

    }

    return report
