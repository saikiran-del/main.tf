Production HPA YAML
apiVersion: autoscaling/v2

kind: HorizontalPodAutoscaler

metadata:

  name: frontend-hpa

spec:

  scaleTargetRef:

    apiVersion: apps/v1

    kind: Deployment

    name: frontend

  minReplicas: 3

  maxReplicas: 10

  metrics:

  - type: Resource

    resource:

      name: cpu

      target:

        type: Utilization

        averageUtilization: 70
