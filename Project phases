Step 10
Jenkinsfile

Create file:

Jenkinsfile

Root of repo.

pipeline {

    agent any

    environment {

        AWS_REGION = 'ap-south-1'

        ECR_REPO = 'self-healing-app'

        ACCOUNT_ID = '123456789012'

    }

    stages {

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/USERNAME/self-healing-platform.git'

            }

        }

        stage('Build Docker Image') {

            steps {

                sh '''
                docker build -t self-healing-app .
                '''

            }

        }

        stage('Login ECR') {

            steps {

                sh '''
                aws ecr get-login-password \
                --region $AWS_REGION | \
                docker login \
                --username AWS \
                --password-stdin \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                '''
            }

        }

        stage('Tag Image') {

            steps {

                sh '''
                docker tag self-healing-app:latest \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:latest
                '''
            }

        }

        stage('Push Image') {

            steps {

                sh '''
                docker push \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:latest
                '''
            }

        }

    }

}
